{
  "env": {
    "GIT_PAGER": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Write",
      "WebSearch",
      "WebFetch",
      "mcp__notion__*",
      "mcp__temporal-docs__*",
      "Edit(~/.claude/skills/live-transcribe/**)"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      ""
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1753986113236
  },
  "mcpServers": {
    "notion": {
      "type": "url",
      "url": "https://mcp.notion.com/mcp"
    },
    "temporal-docs": {
      "type": "url",
      "url": "https://temporal.mcp.kapa.ai"
    }
  },
  "model": "opus[1m]"
}
